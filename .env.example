# Copy to .env and adjust for your mini PC.

TZ=Europe/Prague

# RTL-SDR capture settings. Device index 0 means the first connected dongle.
RTL_DEVICE_INDEX=0
RTL_FREQUENCY_RANGE=30M:1000M:10K
RTL_GAIN=22.5
RTL_INTERVAL=1
RTL_CROP=0.28
RTL_CAPTURE_DURATION=1m
RTL_SLEEP_SECONDS=1
STATION_NAME=SA8818

# Shared data paths inside containers.
DATA_DIR=/data
CSV_DIR=/data/csv
PNG_DIR=/data/png
PROCESSED_DIR=/data/processed
FAILED_DIR=/data/failed

# Heatmap rendering settings.
HEATMAP_COLORMAP=afmhot
HEATMAP_COLORBAR=1
HEATMAP_XTICKS=50MHz
HEATMAP_YTICKS=10m
HEATMAP_XLINES=1
HEATMAP_YLINES=1
HEATMAP_POLL_SECONDS=5
HEATMAP_WIDTH_PX=4096
HEATMAP_HEIGHT_PX=2300
HEATMAP_DPI=120
# 0 or empty means "use HEATMAP_WIDTH_PX". Increase to 8192 for more horizontal detail.
HEATMAP_FREQ_BINS=4096

# Web gallery.
WEB_PORT=8080
GALLERY_TITLE=SA8818 Panoramic RTL

# SpyServer for the second RTL-SDR dongle.
# Airspy's Linux x86_64 build requires a 64-bit Intel/AMD CPU with AVX2/FMA.
SPYSERVER_PORT=5555
SPYSERVER_DEVICE_TYPE=RTL-SDR
# 0 means "first available"; because scanner starts first, SpyServer normally gets the other dongle.
# For deterministic operation, assign unique RTL-SDR serials and put the second dongle serial here.
SPYSERVER_DEVICE_SERIAL=0
SPYSERVER_SAMPLE_RATE=2048000
SPYSERVER_MAXIMUM_CLIENTS=1
SPYSERVER_ALLOW_CONTROL=1
SPYSERVER_LIST_IN_DIRECTORY=0
SPYSERVER_INITIAL_FREQUENCY=145500000
SPYSERVER_INITIAL_GAIN=22
SPYSERVER_FFT_FPS=15
SPYSERVER_FFT_BIN_BITS=15
SPYSERVER_FORCE_8BIT=1
# Optional public directory metadata. Leave empty for local-only use.
SPYSERVER_OWNER_NAME=
SPYSERVER_OWNER_EMAIL=
SPYSERVER_ANTENNA_TYPE=
SPYSERVER_ANTENNA_LOCATION=
SPYSERVER_DESCRIPTION=SA8818 second RTL-SDR
