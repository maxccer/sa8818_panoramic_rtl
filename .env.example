# Copy to .env and adjust for your mini PC.

TZ=Europe/Prague

STATION_NAME=SA8818

# RTL-SDR #1 capture settings.
RTL1_NAME=RTL1
RTL1_DEVICE_INDEX=0
RTL1_FREQUENCY_RANGE=30M:500M:10K
RTL1_GAIN=22.5
RTL1_INTERVAL=1
RTL1_CROP=0.28
RTL1_CAPTURE_DURATION=60m
RTL1_SLEEP_SECONDS=1
RTL1_EXTRA_ARGS=

# RTL-SDR #2 capture settings.
RTL2_NAME=RTL2
RTL2_DEVICE_INDEX=1
RTL2_FREQUENCY_RANGE=500M:1000M:10K
RTL2_GAIN=22.5
RTL2_INTERVAL=1
RTL2_CROP=0.28
RTL2_CAPTURE_DURATION=60m
RTL2_SLEEP_SECONDS=1
RTL2_EXTRA_ARGS=

# Shared data paths inside containers.
DATA_DIR=/data
CSV_DIR=/data/csv
PNG_DIR=/data/png
PROCESSED_DIR=/data/processed
FAILED_DIR=/data/failed

# Heatmap rendering settings.
HEATMAP_COLORMAP=afmhot
HEATMAP_COLORBAR=1
HEATMAP_XTICKS=50MHz
HEATMAP_YTICKS=10m
HEATMAP_XLINES=1
HEATMAP_YLINES=1
HEATMAP_POLL_SECONDS=5
HEATMAP_WIDTH_PX=4096
HEATMAP_HEIGHT_PX=2300
HEATMAP_DPI=120
# 0 or empty means "use HEATMAP_WIDTH_PX". Increase to 8192 for more horizontal detail.
HEATMAP_FREQ_BINS=4096

# Web gallery.
WEB_PORT=8080
GALLERY_TITLE=SA8818 Panoramic RTL
